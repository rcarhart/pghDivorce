# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Cloudflare API (for querying D1 from local scripts)
CF_API_KEY=
CF_EMAIL=

# Google Ads API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Google Sheets API
# Use a separate OAuth client for Sheets (or the same one with both scopes)
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REFRESH_TOKEN=

# The ID of the Google Sheet to export leads into
# Get it from the sheet URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=
